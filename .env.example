# ---------------------------------------------------------------------------
# SkySift environment configuration
#
# Copy this file to `.env.local` and fill in your own values:
#     cp .env.example .env.local
#
# `.env.local` is git-ignored. Never commit a real API key.
# ---------------------------------------------------------------------------

# Your OpenWeatherMap API key. Free tier is sufficient.
# Get one at: https://home.openweathermap.org/api_keys
#
# NOTE: this is intentionally NOT prefixed with NEXT_PUBLIC_. It is read only in
# server-side code (the /api/weather Route Handler), so the key never reaches
# the browser. Prefixing it with NEXT_PUBLIC_ would inline it into the client
# bundle and leak it to anyone who opens devtools.
#
# If this is left empty, SkySift starts in Demo Mode: it serves realistic
# fixture data and shows a banner saying so, instead of failing.
OPENWEATHER_API_KEY=

# Optional. Force fixture data even when a key is present — handy for demos,
# screenshots and offline development. Set to "true" to enable.
SKYSIFT_FORCE_DEMO=
